const TypingIndicator = () => (
  <div style={{ display: "flex", gap: "5px", padding: "16px 20px", alignItems: "center" }}>
    {[0, 1, 2].map(i => (
      <div key={i} style={{
        width: "7px", height: "7px", borderRadius: "50%",
        background: "rgba(255,255,255,0.4)",
        animation: "bounce 1.2s ease-in-out infinite",
        animationDelay: `${i * 0.15}s`
      }} />
    ))}
  </div>
);

function ChatModule({ module, onBack }) {
  const [messages, setMessages] = useState([]);
  const [input, setInput] = useState("");
  const [loading, setLoading] = useState(false);
  const bottomRef = useRef(null);
  const textareaRef = useRef(null);

  useEffect(() => {
    bottomRef.current?.scrollIntoView({ behavior: "smooth" });
  }, [messages, loading]);

  const sendMessage = async (text) => {
    const userText = text || input.trim();
    if (!userText || loading) return;
    setInput("");

    const newMessages = [...messages, { role: "user", content: userText }];
    setMessages(newMessages);
    setLoading(true);

    try {
      const res = await fetch("https://api.anthropic.com/v1/messages", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          model: "claude-sonnet-4-20250514",
          max_tokens: 1000,
          system: module.systemPrompt,
          messages: newMessages
        })
      });
      const data = await res.json();
      const reply = data.content?.map(b => b.text || "").join("") || "Something went wrong.";
      setMessages([...newMessages, { role: "assistant", content: reply }]);
    } catch {
      setMessages([...newMessages, { role: "assistant", content: "Connection error. Please try again." }]);
    } finally {
      setLoading(false);
    }
  };

  const handleKey = (e) => {
    if (e.key === "Enter" && !e.shiftKey) {
      e.preventDefault();
      sendMessage();
    }
  };

  const formatMessage = (text) => {
    return text.split("\n").map((line, i) => {
      if (line.startsWith("**") && line.endsWith("**")) {
        return <div key={i} style={{ fontWeight: 700, color: module.accent, marginTop: i > 0 ? "12px" : 0, fontSize: "13px", letterSpacing: "0.05em", textTransform: "uppercase" }}>{line.replace(/\*\*/g, "")}</div>;
      }
      if (line.startsWith("- ") || line.startsWith("• ")) {
        return <div key={i} style={{ display: "flex", gap: "8px", marginTop: "4px" }}><span style={{ color: module.accent, flexShrink: 0 }}>→</span><span>{line.replace(/^[-•] /, "")}</span></div>;
      }
      const boldInline = line.replace(/\*\*(.+?)\*\*/g, `<strong style="color:${module.accent}">$1</strong>`);
      return <div key={i} style={{ marginTop: i > 0 && line ? "6px" : 0 }} dangerouslySetInnerHTML={{ __html: boldInline || "&nbsp;" }} />;
    });
  };

  return (
    <div style={{
      display: "flex", flexDirection: "column", height: "100%",
      background: "#0A0A0A", fontFamily: "'DM Mono', 'Courier New', monospace"
    }}>
      <style>{`
        @keyframes bounce { 0%,80%,100% { transform:translateY(0) } 40% { transform:translateY(-6px) } }
        @keyframes fadeUp { from { opacity:0; transform:translateY(8px) } to { opacity:1; transform:translateY(0) } }
        ::-webkit-scrollbar { width: 4px }
        ::-webkit-scrollbar-track { background: transparent }
        ::-webkit-scrollbar-thumb { background: #333; border-radius: 2px }
        textarea { resize:none; outline:none; }
        textarea:focus { border-color: ${module.color} !important; }
      `}</style>

      {/* Header */}
      <div style={{
        display: "flex", alignItems: "center", gap: "12px",
        padding: "16px 20px", borderBottom: "1px solid #1A1A1A",
        background: "#0D0D0D"
      }}>
        <button onClick={onBack} style={{
          background: "none", border: "1px solid #2A2A2A", color: "#666",
          cursor: "pointer", padding: "6px 10px", borderRadius: "6px",
          fontSize: "11px", letterSpacing: "0.08em", transition: "all 0.2s"
        }}
          onMouseEnter={e => { e.target.style.borderColor = module.color; e.target.style.color = module.color; }}
          onMouseLeave={e => { e.target.style.borderColor = "#2A2A2A"; e.target.style.color = "#666"; }}
        >← BACK</button>
        <div style={{
          width: "32px", height: "32px", borderRadius: "8px",
          background: `linear-gradient(135deg, ${module.color}22, ${module.accent}22)`,
          border: `1px solid ${module.color}44`,
          display: "flex", alignItems: "center", justifyContent: "center",
          fontSize: "16px", color: module.color
        }}>{module.icon}</div>
        <div>
          <div style={{ fontSize: "13px", fontWeight: 700, color: "#F0F0F0", letterSpacing: "0.05em" }}>{module.label.toUpperCase()}</div>
          <div style={{ fontSize: "10px", color: "#555", letterSpacing: "0.08em" }}>AI SPECIALIST ACTIVE</div>
        </div>
        <div style={{
          marginLeft: "auto", display: "flex", alignItems: "center", gap: "6px",
          fontSize: "10px", color: module.color, letterSpacing: "0.08em"
        }}>
          <div style={{ width: "6px", height: "6px", borderRadius: "50%", background: module.color, animation: "bounce 2s infinite" }} />
          LIVE
        </div>
      </div>

      {/* Messages */}
      <div style={{ flex: 1, overflowY: "auto", padding: "20px", display: "flex", flexDirection: "column", gap: "16px" }}>
        {messages.length === 0 && (
          <div style={{ animation: "fadeUp 0.5s ease" }}>
            <div style={{
              background: `linear-gradient(135deg, ${module.color}15, ${module.accent}08)`,
              border: `1px solid ${module.color}30`,
              borderRadius: "12px", padding: "20px", marginBottom: "20px"
            }}>
              <div style={{ fontSize: "13px", color: module.accent, marginBottom: "8px", letterSpacing: "0.08em", fontWeight: 700 }}>
                {module.icon} {module.label.toUpperCase()} SPECIALIST
              </div>
              <div style={{ fontSize: "12px", color: "#888", lineHeight: 1.7 }}>
                Your dedicated AI expert is ready. Ask anything about {module.label.toLowerCase()} or try an example below.
              </div>
            </div>
            <div style={{ fontSize: "10px", color: "#555", marginBottom: "10px", letterSpacing: "0.1em" }}>QUICK STARTS</div>
            <div style={{ display: "flex", flexDirection: "column", gap: "8px" }}>
              {module.examples.map((ex, i) => (
                <button key={i} onClick={() => sendMessage(ex)} style={{
                  background: "#111", border: "1px solid #222", borderRadius: "8px",
                  padding: "12px 14px", textAlign: "left", cursor: "pointer",
                  fontSize: "11px", color: "#999", letterSpacing: "0.02em", lineHeight: 1.5,
                  transition: "all 0.2s"
                }}
                  onMouseEnter={e => { e.currentTarget.style.borderColor = module.color + "60"; e.currentTarget.style.color = "#ccc"; e.currentTarget.style.background = "#141414"; }}
                  onMouseLeave={e => { e.currentTarget.style.borderColor = "#222"; e.currentTarget.style.color = "#999"; e.currentTarget.style.background = "#111"; }}
                >
                  <span style={{ color: module.color, marginRight: "8px" }}>→</span>{ex}
                </button>
              ))}
            </div>
          </div>
        )}

        {messages.map((msg, i) => (
          <div key={i} style={{
            animation: "fadeUp 0.3s ease",
            display: "flex", flexDirection: "column",
            alignItems: msg.role === "user" ? "flex-end" : "flex-start"
          }}>
            {msg.role === "user" ? (
              <div style={{
                background: `linear-gradient(135deg, ${module.color}, ${module.accent})`,
                borderRadius: "12px 12px 4px 12px",
                padding: "12px 16px", maxWidth: "75%",
                fontSize: "12px", color: "#000", fontWeight: 500, lineHeight: 1.6
              }}>{msg.content}</div>
            ) : (
              <div style={{
                background: "#111", border: "1px solid #1E1E1E",
                borderRadius: "12px 12px 12px 4px",
                padding: "14px 18px", maxWidth: "90%",
                fontSize: "12px", color: "#D0D0D0", lineHeight: 1.8
              }}>
                <div style={{ marginBottom: "6px", fontSize: "10px", color: module.color, letterSpacing: "0.1em" }}>
                  {module.icon} {module.label.toUpperCase()}
                </div>
                {formatMessage(msg.content)}
              </div>
            )}
          </div>
        ))}

        {loading && (
          <div style={{ animation: "fadeUp 0.3s ease" }}>
            <div style={{
              background: "#111", border: "1px solid #1E1E1E",
              borderRadius: "12px 12px 12px 4px", display: "inline-block"
            }}>
              <TypingIndicator />
            </div>
          </div>
        )}
        <div ref={bottomRef} />
      </div>

      {/* Input */}
      <div style={{ padding: "16px 20px", borderTop: "1px solid #1A1A1A", background: "#0D0D0D" }}>
        <div style={{ display: "flex", gap: "10px", alignItems: "flex-end" }}>
          <textarea
            ref={textareaRef}
            value={input}
            onChange={e => setInput(e.target.value)}
            onKeyDown={handleKey}
            placeholder={module.placeholder}
            rows={2}
            style={{
              flex: 1, background: "#111", border: "1px solid #2A2A2A",
              borderRadius: "10px", padding: "12px 14px",
              color: "#E0E0E0", fontSize: "12px", lineHeight: 1.6,
              fontFamily: "inherit", transition: "border-color 0.2s",
              maxHeight: "120px"
            }}
          />
          <button onClick={() => sendMessage()} disabled={!input.trim() || loading} style={{
            background: input.trim() && !loading ? `linear-gradient(135deg, ${module.color}, ${module.accent})` : "#1A1A1A",
            border: "none", borderRadius: "10px", padding: "12px 18px",
            color: input.trim() && !loading ? "#000" : "#444",
            cursor: input.trim() && !loading ? "pointer" : "not-allowed",
            fontSize: "14px", transition: "all 0.2s", flexShrink: 0
          }}>→</button>
        </div>
        <div style={{ marginTop: "8px", fontSize: "10px", color: "#444", letterSpacing: "0.05em", textAlign: "center" }}>
          SHIFT+ENTER FOR NEW LINE · ENTER TO SEND
        </div>
      </div>
    </div>
  );
}

